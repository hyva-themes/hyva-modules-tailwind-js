{
  "name": "@hyva-themes/hyva-modules",
  "version": "1.3.0",
  "description": "Hyvä-themes TailwindCSS utility functions",
  "type": "module",
  "homepage": "https://hyva.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/hyva-themes/hyva-modules-tailwind-js.git"
  },
  "bugs": {
    "email": "info@hyva.io"
  },
  "author": "Hyvä Themes BV",
  "license": "OSL-3.0",
  "keywords": [
    "hyva",
    "magento",
    "tailwindcss"
  ],
  "files": [
    "bin",
    "src",
    "css"
  ],
  "main": "src/index.cjs",
  "module": "src/index.js",
  "style": "css/index.css",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./src/index.cjs",
      "default": "./src/index.cjs"
    },
    "./tailwind-css-props": {
      "import": "./src/tailwind-css-props.js",
      "require": "./src/tailwind-css-props.cjs",
      "default": "./src/tailwind-css-props.cjs"
    },
    "./*": "./*"
  },
  "bin": {
    "hyva-init": "./bin/init-config.js",
    "hyva-sources": "./bin/generate-sources.js",
    "hyva-tokens": "./bin/generate-tokens.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "@fylgja/props-builder": "^2.1.0",
    "deepmerge": "^4.3.1"
  },
  "devDependencies": {
    "tailwindcss": "^4.2.1"
  }
}
